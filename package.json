{
	"name": "@vdegenne/tts-server",
	"version": "0.1.12",
	"description": "",
	"type": "module",
	"exports": {
		".": {
			"import": "./lib/api.js",
			"types": "./lib/api.d.ts"
		}
	},
	"files": [
		"./lib/api.js",
		"./lib/api.d.ts",
		"./lib/voice.js",
		"./lib/voice.d.ts",
		"./lib/types.js",
		"./lib/types.d.ts",
		"./lib/AudioManager.js",
		"./lib/AudioManager.d.ts"
	],
	"scripts": {
		"build": "wireit",
		"start:server": "wireit"
	},
	"devDependencies": {
		"@google-cloud/text-to-speech": "^6.4.1",
		"@vdegenne/koa": "^0.1.49",
		"asian-regexps": "^5.1.0",
		"google-auth-library": "^10.5.0",
		"typescript": "^6.0.3",
		"wireit": "^0.14.13"
	},
	"dependencies": {
		"@vdegenne/mini-rest": "^0.3.6"
	},
	"wireit": {
		"build:voice-ts": {
			"command": "node ./scripts/build-voice-ts.ts",
			"files": [
				"./scripts/build-voice-ts.ts"
			],
			"output": [
				"./src/voice.ts"
			]
		},
		"build": {
			"command": "tsc --pretty",
			"clean": "if-file-deleted",
			"dependencies": [
				"build:voice-ts"
			],
			"files": [
				"./tsconfig.json",
				"./src",
				"./.env"
			],
			"output": [
				"./lib"
			]
		},
		"start:server": {
			"service": true,
			"command": "node ./lib/server.js",
			"dependencies": [
				"build"
			]
		}
	}
}
